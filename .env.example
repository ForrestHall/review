# Public site URL (no trailing slash)
# Use your Railway URL during testing, then your custom domain at launch.
NEXT_PUBLIC_SITE_URL=https://rvwarrantyreview.com

# Optional: override domain used in copy/metadata
# NEXT_PUBLIC_SITE_DOMAIN=rvwarrantyreview.com

# Persistent storage for owner-submitted reviews (Railway Volume mount path)
# Create a Volume in Railway, mount at /data, then set:
# DATA_DIR=/data

# Google Analytics 4 measurement ID. Defaults to G-RMSCHQPTV5; set to override.
# NEXT_PUBLIC_GA_ID=G-RMSCHQPTV5

# Google Search Console HTML-tag verification value (content attribute only).
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
